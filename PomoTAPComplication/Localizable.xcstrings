    "Control_StartPause_Desc": {
      "comment": "启停控件描述",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start or pause your Pomodoro from Control Center or the Action button"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コントロールセンターやアクションボタンからポモドーロを開始・一時停止"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "제어 센터나 액션 버튼에서 포모도로를 시작하거나 일시정지"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在控制中心或操作按钮一键启停番茄钟"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在控制中心或操作按鈕一鍵啟停番茄鐘"
          }
        }
      }
    },
